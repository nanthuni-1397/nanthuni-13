#include <stdio.h>
void main() 
{
    char source[100], destination[100];
    int i;

    printf("Enter a string: ");
    scanf("%[^\n]s", source);
    for (i = 0; source[i] != '\0'; i++) 
    {
        destination[i] = source[i];
    }
    destination[i] = '\0';

    printf("Source: %s\n", source);
    printf("Destination: %s\n", destination);
}
