#include <stdio.h>
void main() 
{
    int a[100][100],i,j,m,n;
    printf("enter matrix limits");
    scanf("%d%d",&m,&n);
    printf("enter matrix values");
    for (i=0;i<m;i++)
    {
        for (j=0;j<n;j++)
        {
            scanf("%d",&a[i][j]);
        }

    }
    for (i=0;i<n;i++)
    {
        printf("\n");
        for (j=0;j<m;j++)
        {
            printf("%d\t",a[j][i]);
        }

    }
}
