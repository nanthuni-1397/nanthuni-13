#include <stdio.h>
#include <string.h>

int main() 
{
    char str1[100], str2[100];
    int choice, l, cmp;

    do {
        printf("1. String length\n2. String copy\n3. String compare\n4. String concatenate\n5. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);
        switch (choice)
        {
            case 1:
                printf("Enter the string: ");
                scanf(" %[^\n]", str1);
                l = strlen(str1);
                printf("Length of the string is %d\n", l);
                break;

            case 2:
                printf("Enter the string: ");
                scanf(" %[^\n]", str1);
                printf("Enter another string: ");
                scanf(" %[^\n]", str2);
                strcpy(str1, str2);
                printf("String 1 is: %s\n", str1);
                printf("String 2 is: %s\n", str2);
                break;

            case 3:
                printf("Enter the string: ");
                scanf(" %[^\n]", str1);
                printf("Enter another string: ");
                scanf(" %[^\n]", str2);
                cmp= strcmp(str1, str2);
                printf("Comparison result: %d\n", cmp);
                printf("String 1 is: %s\n", str1);
                printf("String 2 is: %s\n", str2);
                break;

            case 4:
                printf("Enter the string: ");
                scanf(" %[^\n]", str1);
                printf("Enter another string: ");
                scanf(" %[^\n]", str2);
                strcat(str1, str2);
                printf("string 1 is: %s\n", str1);
                printf("String 2 is: %s\n", str2);
                break;

            case 5:
                printf("Exiting program. Goodbye!\n");
                break;

            default:
                printf("Invalid choice! Please enter a number between 1 and 5.\n");
        }
    } while (choice > 5);
}
