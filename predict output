// for loop
#include <stdio.h>
void main() 
{
    for (int i=0;i<5;i++)
    {
        for (int j=5;j>=1;j--)
        {
            printf("%d\t%d",i,j);
        }
        printf("\n");
    }
}

// while loop
#include <stdio.h>
void main() 
{
   int i=0;
    while (i<5)
    {
        int j=5;
        while (j>=1)
        {
            
            printf("%d\t%d",i,j);
            j--;
        }
        printf("\n");
        i++;
    }
}

// do while loop
#include <stdio.h>
void main() 
{
    int i=0;
   do
    {
        int j=5;
        do
        {
            printf("%d\t%d",i,j);
            j--;
        }
        while(j>=1);
        printf("\n");
        i++;
    }
    while(i<5);
}
