#include <stdio.h>
#include<math.h>
void main() 
{
    int dr,sc,hc,a,b;
    float eoq,tbo;
    printf("enter the demand rate");
    scanf("%d",&dr);
    printf("enter the setup cost");
    scanf("%d",&sc);
    printf("enter the holding cost per item per unit time");
    scanf("%d",&hc);
    eoq=sqrt(2*dr*sc)/hc;
    a=2*sc;
    b=hc*dr;
    tbo=sqrt(a/b);
    printf("the economic order quantity is %d\ntime between orders is %d",eoq,tbo);
}
